# ── LLM API ───────────────────────────────────────────────
# Works with any OpenAI-compatible provider
# Ollama cloud: https://ollama.com/settings/keys
# Anthropic: https://console.anthropic.com
API_KEY=your-api-key-here
API_BASE_URL=https://ollama.com

# ── Models ────────────────────────────────────────────────
# Intent parsing — use a fast/small model
INTENT_MODEL=gemma3:4b
# Narrative generation — use a quality model
NARRATIVE_MODEL=gemma3:27b

# ── NCBI (for PubMed literature fetching) ─────────────────
# Free registration at: https://www.ncbi.nlm.nih.gov/account/
NCBI_API_KEY=
NCBI_EMAIL=your@email.com

# ── Paths ─────────────────────────────────────────────────
DATABASE_PATH=amr_sentinel.db
CHROMA_PATH=chroma_store

# ── Server ────────────────────────────────────────────────
PORT=8000
